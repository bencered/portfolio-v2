---
const pathname = Astro.url.pathname;

const links = [
  { href: "/", label: "Overview" },
  { href: "/ramblings", label: "Writing" },
  { href: "/reading", label: "Reading" },
  { href: "/quotes", label: "Quotes" },
  { href: "https://github.com/bencered", label: "GitHub ↗" },
  { href: "https://linkedin.com/in/bence-redmond", label: "LinkedIn ↗" },
];

function isActive(href: string): boolean {
  if (href.startsWith("http")) return false;
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
}
---

<nav class="mobile-nav">
  <div class="mobile-nav-header">
    <a href="/" class="mobile-nav-logo">
      <span style="color:#4C74FF">/</span>bence.red
    </a>
    <button class="mobile-nav-toggle" id="mobile-toggle" aria-label="Toggle menu">
      <span></span>
      <span></span>
    </button>
  </div>
  <div class="mobile-nav-links" id="mobile-links">
    <div class="mobile-nav-links-inner">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={["mobile-nav-link", { active: isActive(link.href) }]}
          {...(link.href.startsWith("http") ? { target: "_blank", rel: "noopener noreferrer" } : {})}
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('mobile-toggle');
  const links = document.getElementById('mobile-links');

  toggle?.addEventListener('click', () => {
    links?.classList.toggle('open');
  });
</script>
