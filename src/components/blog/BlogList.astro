---
import BlogItem from "./BlogItem.astro";
import { getCollection } from "astro:content";

interface Props {
  compact?: boolean;
  limit?: number;
}

const { compact = false, limit } = Astro.props;
const allPosts = await getCollection("ramblings");
const sorted = allPosts.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
const posts = limit ? sorted.slice(0, limit) : sorted;
---

{posts.map((post) => <BlogItem post={post} compact={compact} />)}
