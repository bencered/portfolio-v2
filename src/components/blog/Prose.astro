---
---

<div class="prose-content">
    <slot />
</div>

<style>
.prose-content {
    font-size: 0.9rem;
    line-height: 1.75;
    color: rgba(255,255,255,0.72);
}

.prose-content h1,
.prose-content h2,
.prose-content h3,
.prose-content h4 {
    font-family: var(--font-title);
    color: rgba(255,255,255,0.9);
    font-weight: 600;
    line-height: 1.3;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
}

.prose-content h1 { font-size: 1.75rem; }
.prose-content h2 { font-size: 1.25rem; }
.prose-content h3 { font-size: 1.05rem; }

.prose-content p { margin-bottom: 1rem; }

.prose-content a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 0.15s ease;
}
.prose-content a:hover { opacity: 0.75; }

.prose-content code {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    background: rgba(255,255,255,0.06);
    padding: 0.1rem 0.35rem;
    border-radius: 0.25rem;
    color: rgba(255,255,255,0.8);
}

.prose-content pre {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 0.5rem;
    padding: 1rem;
    overflow-x: auto;
    margin: 1.25rem 0;
}
.prose-content pre code {
    background: none;
    padding: 0;
}

.prose-content ul,
.prose-content ol {
    padding-left: 1.25rem;
    margin-bottom: 1rem;
}

.prose-content li { margin-bottom: 0.25rem; }
.prose-content li::marker { color: rgba(255,255,255,0.25); }

.prose-content blockquote {
    border-left: 2px solid rgba(255,255,255,0.12);
    padding-left: 1rem;
    margin: 1rem 0;
    color: rgba(255,255,255,0.5);
    font-style: italic;
}

.prose-content img {
    border-radius: 0.5rem;
    max-width: 100%;
    margin: 1.5rem 0;
}

.prose-content hr {
    border: none;
    border-top: 1px solid rgba(255,255,255,0.08);
    margin: 2rem 0;
}
</style>
