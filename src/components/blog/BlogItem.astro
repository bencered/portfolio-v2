---
const { post } = Astro.props;
const pData = post.data;
const postLink = "ramblings/" + pData.slug;
const postDate = new Date(pData.pubDate);
const postDateStr = postDate.toLocaleDateString("en-IE", { year: "numeric", month: "short", day: "numeric" });
---

<a href={postLink} class="block group py-3 px-2 -mx-2 rounded-md hover:bg-[rgba(0,0,0,0.03)] transition-colors duration-150">
  <div class="flex items-baseline justify-between gap-4">
    <span class="text-[14px] text-[#333] group-hover:text-[#111] transition-colors duration-150 font-medium">
      {pData.title}
    </span>
    <span class="text-[12px] text-[#bbb] font-mono shrink-0">{postDateStr}</span>
  </div>
  {pData.description && (
    <p class="text-[13px] text-[#888] mt-0.5 leading-relaxed">{pData.description}</p>
  )}
  {pData.tags && pData.tags.length > 0 && (
    <ul class="mt-1.5 flex flex-wrap gap-1">
      {pData.tags.map((tag: string) => (
        <li class="text-[11px] font-mono text-[#999] bg-[rgba(0,0,0,0.04)] px-1.5 py-0.5 rounded">
          #{tag}
        </li>
      ))}
    </ul>
  )}
</a>
