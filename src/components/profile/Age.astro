<span id="age-counter">19.00</span>
<script>
    function updateAge() {
        const el = document.querySelector("#age-counter");
        if (!el) return;
        const interval = setInterval(() => {
            const born = 1142467200000;
            const age = (Date.now() - born) / 31557600000;
            el.textContent = age.toFixed(2);
        }, 100);
        return () => clearInterval(interval);
    }
    let cleanup = updateAge();
    document.addEventListener('astro:page-load', () => {
        if (cleanup) cleanup();
        cleanup = updateAge();
    });
</script>
