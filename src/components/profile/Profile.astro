---
import Age from "./Age.astro";
---

<header class="mb-12 relative">
  <!-- Announcement banner -->
  <a href="https://github.com/bencered" target="_blank" class="inline-flex items-center gap-2 text-[13px] text-[#666] mb-5 hover:text-[#111] transition-colors duration-150 group">
    <span class="w-1.5 h-1.5 rounded-full bg-[#4C74FF] inline-block"></span>
    <span>Available for internships &amp; work · <Age /> yrs old</span>
    <span class="text-[#4C74FF] group-hover:translate-x-0.5 transition-transform duration-150">→</span>
  </a>

  <!-- Hero h1 with text treatments -->
  <div class="relative">
    <!-- GitHub snippet (positioned top-right of hero, agentation-style) -->
    <button
      class="install-snippet absolute right-0 top-1 hidden sm:inline-flex"
      onclick="navigator.clipboard.writeText('bencered').then(() => this.textContent = 'copied!')"
      title="Copy GitHub username"
    >
      github.com/bencered
    </button>

    <h1 class="text-[2.6rem] sm:text-[3.2rem] font-bold tracking-tight leading-[1.1] text-[#111] mb-4 pr-0 sm:pr-48">
      <span class="text-highlight">Build things.</span><br />
      Make them <span class="sketchy-underline">matter.</span>
    </h1>
  </div>

  <p class="text-[15px] text-[#666] max-w-[480px] leading-relaxed">
    First-year <a href="https://ise.ul.ie" target="_blank" class="text-[#111] underline decoration-[rgba(0,0,0,0.2)] underline-offset-2 hover:decoration-[#4C74FF] transition-colors">Immersive Software Engineering</a> student in Limerick, Ireland.
    Programming since age 11, building for the web since 2023.
  </p>
</header>
