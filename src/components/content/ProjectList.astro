---
import ProjectCard from "./ProjectCard.astro";
---

<section id="projects" class="mb-14 scroll-mt-8">
  <h2 class="text-[11px] uppercase tracking-widest text-[#aaa] font-medium mb-6">Projects</h2>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
    <ProjectCard
      name="BetterExams.ie"
      description="Alternative to examinations.ie — easy access to past papers and resources without the 2006-era form system."
      href="/projects/betterexams"
      tags={["Next.js", "React", "Tailwind CSS", "TypeScript"]}
      imagePath="/betterexams.png"
      featured={true}
    />
    <ProjectCard
      name="BetterExams Points"
      description="Grades tracker for Leaving Cert students. Auto-calculates total CAO points and tracks past results."
      href="/projects/betterexams-points"
      tags={["React", "Tailwind CSS"]}
      imagePath="/bep_home.webp"
    />
    <ProjectCard
      name="Why Vim?"
      description="Whitepaper-style site to help people get comfortable with Vim motions."
      href="/projects/why-vim"
      tags={["React", "Next.js", "Tailwind CSS", "TypeScript"]}
      imagePath="/why-vim.png"
      featured
    />
    <ProjectCard
      name="Modern ISE Website"
      description="A weekend exercise stepping outside my design comfort zone — radical redesign of software-engineering.ie."
      href="/projects/modern-ise-website"
      tags={["Next.js", "React", "Tailwind CSS", "Turso", "Prisma"]}
      imagePath="/modern-ise-website.png"
    />
    <ProjectCard
      name="QuoteBoat"
      description="Platform for ISE students to record funny, insightful, or stupid things their friends said."
      href="/projects/quoteboat"
      tags={["Next.js", "React", "Tailwind CSS", "Turso", "Prisma"]}
      imagePath="/quoteboat.png"
    />
    <ProjectCard
      name="Portfolio"
      description="This site. Built with Astro and Tailwind CSS."
      href="/projects/portfolio"
      tags={["Astro", "Tailwind CSS"]}
      imagePath="/portfolio.png"
    />
  </div>
</section>
