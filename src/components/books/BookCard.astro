---
import { Image } from "astro:assets";

const { props } = Astro.props;
const hardcoverUrl = "https://hardcover.app/books/" + props.book.slug;
const year = props.book.release_date.slice(0, 4);
const rating = props.book.rating.toString().slice(0, 4);
const position = props.position;
---

<a href={hardcoverUrl} target="_blank" style="display:block; text-decoration:none; color:inherit; margin-bottom:0.75rem; position:relative;">
    <div style="display:flex; flex-direction:row; gap:1rem; border:1px solid var(--border); border-radius:0.625rem; padding:1rem; background:var(--surface); transition:border-color 0.15s ease, background 0.15s ease; max-height:14rem; overflow:hidden;"
         class="book-card">
        {position !== undefined && (
            <div style={`
                position:absolute; left:-0.25rem; top:1rem;
                width:2rem; height:2rem; border-radius:0.375rem;
                background:var(--bg); border:1px solid var(--border);
                display:flex; align-items:center; justify-content:center;
                font-size:0.75rem; font-weight:700;
                color:${position === 0 ? '#fbbf24' : position === 1 ? 'rgba(255,255,255,0.6)' : 'rgba(255,255,255,0.35)'};
                font-family:var(--font-mono);
            `}>
                #{position + 1}
            </div>
        )}

        <Image
            src={props.book.image.url}
            alt={`Cover of ${props.book.title}`}
            width={80}
            height={120}
            style="max-height:100%; width:auto; flex-shrink:0; border-radius:0.25rem; object-fit:cover;"
        />

        <div style="display:flex; flex-direction:column; gap:0.25rem; overflow:hidden; min-width:0;">
            <p style="font-size:0.6875rem; font-family:var(--font-mono); color:var(--text-muted);">
                {year} · {props.book.pages}p · {rating} ★
            </p>
            <h3 style="font-family:var(--font-title); font-size:1.1rem; font-weight:600; color:var(--text-strong); line-height:1.2;" class="book-title">
                {props.book.title}
            </h3>
            <p style="font-size:0.8125rem; color:var(--text-muted);">
                {props.book.contributions[0].author.name}
            </p>
            <p style="font-size:0.8125rem; color:var(--text-muted); line-height:1.5; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; margin-top:0.25rem;">
                {props.book.description}
            </p>
        </div>
    </div>
</a>

<style>
.book-card:hover { border-color: rgba(255,255,255,0.14); background: rgba(255,255,255,0.06); }
.book-card:hover .book-title { color: var(--accent); }
</style>
