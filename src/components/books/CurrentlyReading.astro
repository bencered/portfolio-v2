---
import BookCard from "./BookCard.astro";

const response = await fetch("https://api.hardcover.app/v1/graphql", {
    method: "POST",
    headers: {
        "Content-Type": "application/json",
        authorization: import.meta.env.HARDCOVER_KEY,
    },
    body: JSON.stringify({
        query: `query CurrentlyReading {
          me {
            user_books(where: {status_id: {_eq: 2}}) {
              id
              book {
                title pages description slug rating release_date
                image { url }
                contributions { author { name } }
              }
            }
          }
        }`,
    }),
});

const json = await response.json();
const currentlyReading = json?.data?.me?.[0]?.user_books ?? [];
---

<h2 class="section-heading">Currently Reading</h2>
{currentlyReading.length === 0
    ? <p style="font-size:0.875rem; color:var(--text-muted);">Nothing tracked right now.</p>
    : currentlyReading.map((book) => <BookCard props={book} />)
}
