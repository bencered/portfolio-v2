---
import BookCard from "./BookCard.astro";

const response = await fetch("https://api.hardcover.app/v1/graphql", {
    method: "POST",
    headers: {
        "Content-Type": "application/json",
        authorization: import.meta.env.HARDCOVER_KEY,
    },
    body: JSON.stringify({
        query: `query TopFive {
          me {
            lists(where: {id: {_eq: 45547}}) {
              list_books(order_by: {position: asc}) {
                position
                book {
                  title pages description slug rating release_date
                  image { url }
                  contributions { author { name } }
                }
              }
            }
          }
        }`,
    }),
});

const json = await response.json();
const topFive = json?.data?.me?.[0]?.lists?.[0]?.list_books ?? [];
---

<h2 class="section-heading">Top Five</h2>
<p style="font-size:0.875rem; color:var(--text-muted); margin-bottom:1rem;">
    My five favourites since I started tracking in mid-2023.
</p>
{topFive.map((book) => <BookCard props={book} />)}
