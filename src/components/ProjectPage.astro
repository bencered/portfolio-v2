---
interface Props {
  name: string;
  date: string;
  tags: string[];
  image: string;
  imageAlt: string;
  github?: string;
  link?: string;
}

const { name, date, tags, image, imageAlt, github, link } = Astro.props;
---

<div style="margin-bottom:2rem">
  <a href="/#projects" style="font-size:0.75rem; color:var(--text-muted); text-decoration:none; display:inline-flex; align-items:center; gap:0.375rem; transition:color 0.15s ease;">
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M19 12H5M5 12L12 19M5 12L12 5"/></svg>
    Projects
  </a>
</div>

<h2 class="section-heading">{date}</h2>

<div style="display:flex; align-items:flex-start; justify-content:space-between; gap:1rem; margin-bottom:1.25rem;">
  <h1 style="font-family:var(--font-title); font-size:2rem; font-weight:600; color:var(--text-strong); letter-spacing:-0.02em; line-height:1.15;">{name}</h1>
  <div style="display:flex; gap:0.5rem; flex-shrink:0; margin-top:0.25rem;">
    {github && (
      <a href={github} target="_blank" rel="noopener noreferrer" style="display:flex; align-items:center; padding:0.375rem; border-radius:0.375rem; background:var(--surface); border:1px solid var(--border); color:var(--text-muted); transition:color 0.15s ease;" aria-label="GitHub">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
      </a>
    )}
    {link && (
      <a href={link} target="_blank" rel="noopener noreferrer" style="display:flex; align-items:center; padding:0.375rem; border-radius:0.375rem; background:var(--surface); border:1px solid var(--border); color:var(--text-muted); transition:color 0.15s ease;" aria-label="Live site">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><path d="M15 3h6v6"/><path d="M10 14L21 3"/></svg>
      </a>
    )}
  </div>
</div>

<div style="display:flex; flex-wrap:wrap; gap:0.5rem; margin-bottom:1.5rem;">
  {tags.map(t => <span class="project-tag">{t}</span>)}
</div>

<img src={image} alt={imageAlt} style="width:100%; border-radius:0.625rem; border:1px solid var(--border); margin-bottom:2rem;" />

<slot />
