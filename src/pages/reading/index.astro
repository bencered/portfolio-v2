    <header>
      <h1 style="font-size:1.75rem; line-height:1.2; margin-bottom:0.5rem;">Reading</h1>
      <p class="tagline">
        Tracked via <a href="https://hardcover.app" target="_blank" style="color:var(--hyperlink-color)">Hardcover</a>.
        Data pulled live from their API.
      </p>
    </header>

    <section>
      <CurrentlyReading />
    </section>

    <section>
      <TopFive />
    </section>
  </article>
</Layout>
