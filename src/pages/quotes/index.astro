---
import Layout from "../../layouts/Layout.astro";
import { quotes } from "../../lib/quotes";
---

<Layout title="Quotes — Bence R.">
  <div class="section">
    <h2 class="section-heading">Favourite Quotes</h2>
    <p style="margin-bottom:1.5rem">Things that have stuck with me.</p>

    {quotes.map((quote) => (
      <div style="padding: 1rem 0; border-bottom: 1px solid var(--border);">
        <p style="font-family: var(--font-mono); font-size: 0.8125rem; color: var(--text); line-height: 1.65; font-style: italic; margin-bottom: 0.5rem !important;">
          "{quote[0]}"
        </p>
        <p style="font-size: 0.6875rem; color: var(--text-muted); margin-top: 0 !important;">— {quote[1]}</p>
      </div>
    ))}
  </div>
</Layout>
