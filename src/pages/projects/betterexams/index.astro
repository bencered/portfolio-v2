---
import Layout from "../../../layouts/Layout.astro";
import ProjectPage from "../../../components/ProjectPage.astro";
---
<Layout title="BetterExams — Bence R.">
  <ProjectPage
    name="BetterExams.ie"
    date="June 2023 – July 2023"
    tags={["Next.js", "React", "Tailwind CSS", "Framer Motion", "TypeScript"]}
    image="/betterexams.png"
    imageAlt="BetterExams home page"
    github="https://github.com/bencered/betterexams"
    link="https://betterexams.ie"
  >
    <div class="section">
      <h2 class="section-heading">What?</h2>
      <p>An alternative to examinations.ie — which proudly displays an e-Government award from 2006. Easy access to past papers and marking schemes without dealing with its form system.</p>
      <h2 class="section-heading" style="margin-top:1.5rem">Why?</h2>
      <p>Improve my web dev skills and save students the seconds they waste daily on that site.</p>
      <h2 class="section-heading" style="margin-top:1.5rem">Learnings</h2>
      <p>First real project in Next.js, Tailwind CSS, Framer Motion, and TypeScript.</p>
    </div>
  </ProjectPage>
</Layout>
