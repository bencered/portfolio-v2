---
import Layout from "../../../layouts/Layout.astro";
import ProjectPage from "../../../components/ProjectPage.astro";
---
<Layout title="BetterExams — Bence R." ogDesc="A better alternative to examinations.ie — easy access to past papers and marking schemes.">
  <ProjectPage
    name="BetterExams.ie"
    date="June 2023 – July 2023"
    tags={["Next.js", "React", "Tailwind CSS", "Framer Motion", "TypeScript"]}
    image="/betterexams.png"
    imageAlt="BetterExams home page"
    github="https://github.com/bencered/betterexams"
    link="https://betterexams.ie"
  >
    <div class="section">
      <h2 class="section-heading">What?</h2>
      <p>I created this site as an alternative to the official examinations.ie website, which is an arguable affront to God. (It proudly displays an e-Government award from 2006. It is as old as I am.)</p>
      <h2 class="section-heading" style="margin-top:1.5rem">Why?</h2>
      <p>The goal from the get-go was to, firstly, improve upon my web-dev skills, and secondly, to save those precious seconds students and teachers spend every day on that hellish site.</p>
      <h2 class="section-heading" style="margin-top:1.5rem">Learnings</h2>
      <p>How to use Next.js, Tailwind CSS, Framer Motion, and TypeScript.</p>
    </div>
  </ProjectPage>
</Layout>
