---
import Layout from "../../../layouts/Layout.astro";
import ProjectPage from "../../../components/ProjectPage.astro";
---
<Layout title="Why Vim? — Bence R.">
  <ProjectPage
    name="Why Vim?"
    date="May 2025 – Present"
    tags={["Next.js", "React", "Tailwind CSS", "Framer Motion", "TypeScript"]}
    image="/why-vim.png"
    imageAlt="Why Vim landing page"
    github="https://github.com/bencered/why-vim"
    link="https://whyvim.org"
  >
    <div class="section">
      <h2 class="section-heading">What?</h2>
      <p>A work-in-progress site that introduces Vim motions to those unfamiliar with them — interactive, readable, and aimed at making the learning curve less painful.</p>
      <h2 class="section-heading" style="margin-top:1.5rem">Why?</h2>
      <p>I believe optimising your dev workflow leads to exponential productivity gains, and Vim is one of the best ways to do that. Wanted to give back to that community and sharpen my React/TypeScript skills.</p>
      <h2 class="section-heading" style="margin-top:1.5rem">Learnings</h2>
      <p>Advanced React hooks (useContext), Framer Motion animations, technical writing, web design.</p>
    </div>
  </ProjectPage>
</Layout>
