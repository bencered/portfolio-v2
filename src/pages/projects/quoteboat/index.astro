---
import Layout from "../../../layouts/Layout.astro";
import ProjectPage from "../../../components/ProjectPage.astro";
---
<Layout title="QuoteBoat — Bence R.">
  <ProjectPage
    name="QuoteBoat"
    date="October 2024 – Present"
    tags={["Next.js", "React", "Tailwind CSS", "Turso", "Prisma", "TypeScript"]}
    image="/quoteboat.png"
    imageAlt="QuoteBoat home page"
  >
    <div class="section">
      <h2 class="section-heading">What?</h2>
      <p>A platform for ISE students to record the funny, insightful, or stupid things their friends said. Simple single-page design, built with a classmate.</p>
      <h2 class="section-heading" style="margin-top:1.5rem">Why?</h2>
      <p>Fun way to build community in the ISE cohort — and an excuse to build a proper full-stack app with a co-developer.</p>
      <h2 class="section-heading" style="margin-top:1.5rem">Learnings</h2>
      <p>Turso + Prisma for full-stack data, collaborative dev workflow, UX design for simplicity.</p>
    </div>
  </ProjectPage>
</Layout>
