---
import Layout from "../../../layouts/Layout.astro";
import ProjectPage from "../../../components/ProjectPage.astro";
---
<Layout title="QuoteBoat — Bence R." ogDesc="A platform for ISE students to record and share the memorable things their friends say.">
  <ProjectPage
    name="QuoteBoat"
    date="October 2024 – Present"
    tags={["Next.js", "React", "Tailwind CSS", "Turso", "Prisma", "TypeScript"]}
    image="/quoteboat.png"
    imageAlt="The simple single-page design of QuoteBoat"
    github=""
    link=""
  >
    <div class="section">
      <h2 class="section-heading">What?</h2>
      <p>QuoteBoat is a work-in-progress platform that allows ISE students to record funny, insightful, or stupid things that their friends said. It is a place to share and laugh at the things we say.</p>
      <h2 class="section-heading" style="margin-top:1.5rem">Why?</h2>
      <p>A project I started with a classmate to help students in the ISE community share funny quotes and moments. It's a fun way to connect with each other and create a sense of community.</p>
      <h2 class="section-heading" style="margin-top:1.5rem">Learnings</h2>
      <p>Using Turso and Prisma to build a full-stack application. Working with a team to build a project from scratch. The importance of user experience and design.</p>
    </div>
  </ProjectPage>
</Layout>
