---
import Layout from "../../../layouts/Layout.astro";
import ProjectPage from "../../../components/ProjectPage.astro";
---
<Layout title="BetterExams Points — Bence R.">
  <ProjectPage
    name="BetterExams Points"
    date="December 2023 – April 2024"
    tags={["Next.js", "React", "Tailwind CSS", "Turso", "Prisma", "TypeScript"]}
    image="/bep_home.webp"
    imageAlt="BetterExams Points home dashboard"
    github="https://github.com/bencered/points-calculator"
    link="https://points.betterexams.ie"
  >
    <div class="section">
      <h2 class="section-heading">What?</h2>
      <p>A gradebook for Leaving Cert students. Track test results, see your grade progression over time, and calculate the CAO points you'd earn based on your averages.</p>
      <h2 class="section-heading" style="margin-top:1.5rem">Why?</h2>
      <p>The second entry in the BetterExams suite. Taught me a lot about full-stack design — specifically how CRUD apps are structured from end to end.</p>
      <h2 class="section-heading" style="margin-top:1.5rem">Learnings</h2>
      <p>Building a CRUD app from scratch. Prisma for DB management, Next.js SSR, TypeScript throughout.</p>
    </div>
  </ProjectPage>
</Layout>
