---
import Layout from "../../../layouts/Layout.astro";
import ProjectPage from "../../../components/ProjectPage.astro";
---
<Layout title="Portfolio — Bence R.">
  <ProjectPage
    name="Portfolio"
    date="September 2024 – Present"
    tags={["Astro", "Tailwind CSS", "Preact"]}
    image="/portfolio.png"
    imageAlt="Portfolio screenshot"
    github="https://github.com/bencered/portfolio-v2"
    link="https://bence.red"
  >
    <div class="section">
      <h2 class="section-heading">What?</h2>
      <p>This site. Built with Astro, Tailwind CSS, and Preact for interactive components.</p>
      <h2 class="section-heading" style="margin-top:1.5rem">Why?</h2>
      <p>To have a home on the internet that represents what I can do.</p>
      <h2 class="section-heading" style="margin-top:1.5rem">Learnings</h2>
      <p>Astro's island architecture, content collections, Vercel deployments.</p>
    </div>
  </ProjectPage>
</Layout>
