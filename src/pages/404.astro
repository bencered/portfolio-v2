---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 — Bence R.">
    <div style="font-family:var(--font-title);">
        <h1 id="heading" style="font-size:2.5rem; font-weight:600; color:var(--text-strong); line-height:1.2; min-height:3rem;"></h1>
        <p id="hided" style="display:none; font-size:0.875rem; color:var(--text-muted); margin-top:1rem; line-height:1.7; max-width:30rem;"></p>
        <a id="return" href="/" style="display:none; margin-top:1.5rem; font-size:0.8125rem; color:var(--accent); text-decoration:none; font-family:var(--font-mono);">← return home</a>
    </div>
</Layout>

<script>
var i = 0, j = 0;
var txt = "You seem to have lost your way.";
var txt2 = "This is a 404. Let me know if something is supposed to be here. If not,";
var speed = 45;

function typeWriter() {
    if (i < txt.length) {
        document.getElementById("heading").innerHTML += txt.charAt(i++);
        setTimeout(typeWriter, speed);
    } else {
        document.getElementById("hided").style.display = "block";
        if (j < txt2.length) {
            document.getElementById("hided").innerHTML += txt2.charAt(j++);
            setTimeout(typeWriter, speed);
        } else {
            document.getElementById("return").style.display = "inline-flex";
        }
    }
}

typeWriter();
</script>
